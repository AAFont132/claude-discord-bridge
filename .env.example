# Discord Bot Token (from Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=your_bot_token_here

# Discord Channel ID (right-click channel → Copy Channel ID — enable Developer Mode in Discord settings first)
DISCORD_CHANNEL_ID=your_channel_id_here

# Your Discord User ID (right-click your name → Copy User ID)
DISCORD_USER_ID=your_user_id_here

# tmux session name where Claude Code is running (default: claude)
CLAUDE_TMUX_SESSION=claude

# Port for the local HTTP server (default: 8787)
BRIDGE_PORT=8787

# Timeout for permission prompts in seconds (default: 300 = 5 minutes)
PERMISSION_TIMEOUT=300
